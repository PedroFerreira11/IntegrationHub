@model IntegrationHub.Web.Models.Integrations.CreateIntegrationViewModel

@{
    ViewData["Title"] = "Create Integration";
}

<section class="form-shell">
    <div class="page-header page-header--compact">
        <div>
            <span class="eyebrow">Integrations</span>
            <h1>Create integration</h1>
            <p>Define the flow type and select the source and target endpoints.</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="surface-card app-form">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger soft-alert"></div>

        <div class="app-form__grid">
            <div class="app-form__field">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="app-form__field">
                <label asp-for="Type" class="form-label"></label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<IntegrationHub.Domain.Enums.IntegrationType>()" class="form-select"></select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div class="app-form__field">
                <label asp-for="SourceEndpointId" class="form-label">Source Endpoint</label>
                <select asp-for="SourceEndpointId" class="form-select">
                    <option value="">Select source endpoint</option>
                    @foreach (var endpoint in Model.Endpoints)
                    {
                        <option value="@endpoint.Id">@endpoint.Name</option>
                    }
                </select>
                <span asp-validation-for="SourceEndpointId" class="text-danger"></span>
            </div>

            <div class="app-form__field">
                <label asp-for="TargetEndpointId" class="form-label">Target Endpoint</label>
                <select asp-for="TargetEndpointId" class="form-select">
                    <option value="">Select target endpoint</option>
                    @foreach (var endpoint in Model.Endpoints)
                    {
                        <option value="@endpoint.Id">@endpoint.Name</option>
                    }
                </select>
                <span asp-validation-for="TargetEndpointId" class="text-danger"></span>
            </div>
        </div>

        <label class="toggle-field">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <span>
                <strong>Active integration</strong>
                <small>It becomes available for execution as soon as it is created.</small>
            </span>
        </label>

        <div class="action-group">
            <button type="submit" class="btn btn-primary">Create integration</button>
            <a asp-controller="Integrations" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</section>
