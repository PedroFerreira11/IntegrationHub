<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IntegrationHub</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IntegrationHub.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <header class="app-header">
            <nav class="navbar navbar-expand-lg">
                <div class="container app-nav">
                    <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="brand-mark__badge">IH</span>
                        <span>
                            <span class="brand-mark__title">IntegrationHub</span>
                            <span class="brand-mark__subtitle">Control Center</span>
                        </span>
                    </a>
                    <button class="navbar-toggler app-nav__toggle" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse">
                        <ul class="navbar-nav ms-auto align-items-lg-center app-nav__links">
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Integrations" asp-action="Index">Integrations</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Endpoints" asp-action="Index">Endpoints</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <div class="app-backdrop">
            <div class="app-backdrop__glow app-backdrop__glow--one"></div>
            <div class="app-backdrop__glow app-backdrop__glow--two"></div>
        </div>

        <main role="main" class="container app-main">
            @RenderBody()
        </main>

        <footer class="app-footer">
            <div class="container d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2">
                <div>
                    <strong>IntegrationHub</strong>
                    <span class="text-muted">centralizes endpoints, integrations, and runs.</span>
                </div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
