@model IntegrationHub.Web.Models.Endpoints.EndpointDto

@{
    ViewData["Title"] = "Details";
}

<h2>Endpoint Details</h2>

<p><strong>Id:</strong> @Model.Id</p>
<p><strong>Name:</strong> @Model.Name</p>
<p><strong>Base Url:</strong> @Model.BaseUrl</p>
<p><strong>Active:</strong> @Model.IsActive</p>

<div class="d-flex gap-2">
    <a asp-controller="Endpoints"
       asp-action="Index"
       class="btn btn-outline-secondary">
        Back
    </a>
</div>