@model IntegrationHub.Web.Models.Endpoints.EndpointDto

@{
    ViewData["Title"] = "Details";
}

<section class="page-header page-header--compact">
    <div>
        <span class="eyebrow">Endpoint</span>
        <h1>@Model.Name</h1>
        <p>Core information for the external system registered in the platform.</p>
    </div>
</section>

<section class="details-grid details-grid--single">
    <article class="surface-card detail-card">
        <div class="detail-list">
            <div>
                <span class="detail-list__label">Identifier</span>
                <strong>@Model.Id</strong>
            </div>
            <div>
                <span class="detail-list__label">Base URL</span>
                <strong>@Model.BaseUrl</strong>
            </div>
            <div>
                <span class="detail-list__label">Status</span>
                <strong>@(Model.IsActive ? "Active" : "Inactive")</strong>
            </div>
        </div>

        <div class="action-group">
            <a asp-controller="Endpoints" asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </article>
</section>
