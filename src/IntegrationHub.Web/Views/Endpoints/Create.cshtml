@model IntegrationHub.Web.Models.Endpoints.CreateEndpointDto

@{
    ViewData["Title"] = "Create Endpoint";
}

<section class="form-shell">
    <div class="page-header page-header--compact">
        <div>
            <span class="eyebrow">Endpoints</span>
            <h1>Create endpoint</h1>
            <p>Register an external system with a base URL and authentication settings.</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="surface-card app-form">
        <div asp-validation-summary="All" class="alert alert-danger soft-alert"></div>

        <div class="app-form__grid">
            <div class="app-form__field">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="app-form__field">
                <label asp-for="BaseUrl" class="form-label"></label>
                <input asp-for="BaseUrl" class="form-control" />
                <span asp-validation-for="BaseUrl" class="text-danger"></span>
            </div>
            <div class="app-form__field">
                <label asp-for="ApiKey" class="form-label"></label>
                <input asp-for="ApiKey" class="form-control" />
                <span asp-validation-for="ApiKey" class="text-danger"></span>
            </div>
            <div class="app-form__field">
                <label asp-for="ApiKeyHeaderName" class="form-label"></label>
                <input asp-for="ApiKeyHeaderName" class="form-control" />
                <span asp-validation-for="ApiKeyHeaderName" class="text-danger"></span>
            </div>
        </div>

        <label class="toggle-field">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
            <span>
                <strong>Active endpoint</strong>
                <small>Makes the endpoint eligible for new integrations.</small>
            </span>
        </label>

        <div class="action-group">
            <button type="submit" class="btn btn-primary">Create endpoint</button>
            <a asp-controller="Endpoints" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</section>
