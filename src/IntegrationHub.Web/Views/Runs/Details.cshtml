@model IntegrationHub.Web.Models.Runs.RunDetailsResponseDto

@{
    ViewData["Title"] = "Run Details";
}

<section class="page-header page-header--compact">
    <div>
        <span class="eyebrow">Run Monitor</span>
        <h1>Run details</h1>
        <p>Status, retries, and logs updated automatically.</p>
    </div>
</section>

<section class="details-grid">
    <article class="surface-card detail-card">
        <div class="detail-list">
            <div>
                <span class="detail-list__label">Run ID</span>
                <strong>@Model.Id</strong>
            </div>
            <div>
                <span class="detail-list__label">Integration ID</span>
                <strong>@Model.IntegrationId</strong>
            </div>
            <div>
                <span class="detail-list__label">Status</span>
                <strong id="run-status">@Model.Status</strong>
            </div>
            <div>
                <span class="detail-list__label">Created At</span>
                <strong id="run-createdAt">@Model.CreatedAt</strong>
            </div>
            <div>
                <span class="detail-list__label">Started At</span>
                <strong id="run-startedAt">@(Model.StartedAt?.ToString() ?? "-")</strong>
            </div>
            <div>
                <span class="detail-list__label">Finished At</span>
                <strong id="run-finishedAt">@(Model.FinishedAt?.ToString() ?? "-")</strong>
            </div>
            <div>
                <span class="detail-list__label">Retry Count</span>
                <strong id="run-retries">@Model.RetryCount / @Model.MaxRetries</strong>
            </div>
            <div>
                <span class="detail-list__label">Next Retry At</span>
                <strong id="run-nextRetryAt">@(Model.NextRetryAt?.ToString() ?? "-")</strong>
            </div>
            <div>
                <span class="detail-list__label">Error</span>
                <strong id="run-error">@(Model.ErrorMessage ?? "-")</strong>
            </div>
        </div>
    </article>

    <aside class="surface-card detail-card detail-card--accent">
        <span class="eyebrow">Live Feed</span>
        <h2>Execution logs</h2>
        <p>The panel below updates through polling to reflect the current execution.</p>
    </aside>
</section>

<section class="surface-card log-panel">
    <h2>Logs</h2>
    <pre id="run-logs" class="log-panel__console">
Loading logs... *
    </pre>
</section>

@section Scripts
{
    <script>
        const runId = '@Model.Id';
        const statusUrl = `/Runs/Status/${runId}`;
        const logsUrl = `/Runs/Logs/${runId}`;

        let pollIntervalId = null;

        function formatDate(value) {
            return value ?? "-";
        }

        function isTerminal(status) {
            return status === "Success" || status === "Failed";
        }

        async function loadRunStatus() {
            const response = await fetch(statusUrl);
            if (!response.ok) return null;

            const run = await response.json();

            document.getElementById("run-status").textContent = run.status;
            document.getElementById("run-createdAt").textContent = formatDate(run.createdAt);
            document.getElementById("run-startedAt").textContent = formatDate(run.startedAt);
            document.getElementById("run-finishedAt").textContent = formatDate(run.finishedAt);
            document.getElementById("run-retries").textContent = `${run.retryCount} / ${run.maxRetries}`;
            document.getElementById("run-nextRetryAt").textContent = formatDate(run.nextRetryAt);
            document.getElementById("run-error").textContent = formatDate(run.errorMessage);

            return run;
        }

        async function loadRunLogs() {
            const response = await fetch(logsUrl);
            if (!response.ok) return;

            const logs = await response.json();

            const content = logs.length === 0
                ? "No logs yet."
                : logs.map(log => `[${log.timestamp}] ${log.level} : ${log.message}`).join('\n');

            document.getElementById("run-logs").textContent = content;
        }

        async function refreshRun() {
            try {
                const run = await loadRunStatus();
                await loadRunLogs();

                if (run && isTerminal(run.status) && pollIntervalId) {
                    clearInterval(pollIntervalId);
                    pollIntervalId = null;
                }
            } catch (error) {
                console.error("Failed to refresh run.", error);
            }
        }

        refreshRun();
        pollIntervalId = setInterval(refreshRun, 500);
    </script>
}
